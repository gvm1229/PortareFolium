---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
    title="404 — 페이지를 찾을 수 없음"
    description="요청하신 페이지가 존재하지 않습니다."
>
    <div
        class="mx-auto flex max-w-2xl flex-col items-center px-4 py-24 text-center"
    >
        <p
            class="mb-4 text-[8rem] leading-none font-black text-(--color-border)"
        >
            404
        </p>
        <h1 class="mb-3 text-2xl font-bold text-(--color-foreground)">
            페이지를 찾을 수 없습니다
        </h1>
        <p class="mb-8 leading-relaxed text-(--color-muted)">
            요청하신 페이지가 존재하지 않습니다.<br />
            <span id="countdown">5</span>초 후 홈페이지로 자동으로 이동합니다.
        </p>
        <a
            href="/"
            class="rounded-lg bg-(--color-accent) px-6 py-3 font-semibold whitespace-nowrap text-(--color-on-accent) transition-opacity hover:opacity-90"
        >
            홈으로 이동
        </a>
    </div>
</BaseLayout>

<script>
    let seconds = 5;
    const el = document.getElementById("countdown");
    const tick = setInterval(() => {
        seconds--;
        if (el) el.textContent = String(seconds);
        if (seconds <= 0) {
            clearInterval(tick);
            window.location.href = "/";
        }
    }, 1000);
</script>
