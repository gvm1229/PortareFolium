# ────────────────────────────────────────────────────────────
# Supabase 설정
# Supabase 대시보드 → Settings → API 에서 값을 확인.
# ────────────────────────────────────────────────────────────

# 프로젝트 URL (클라이언트·빌드 타임 공통)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon 키 — 브라우저 런타임 클라이언트용 (RLS 적용, 공개 OK)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role 키 — 빌드 타임 전용 (RLS 우회, 절대 공개하지 말 것)
# Vercel 환경변수에 추가할 때 "Preview/Production" 환경에만 등록.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ────────────────────────────────────────────────────────────
# Vercel Deploy Hook — 어드민에서 "게시" 시 정적 빌드를 재트리거하는 URL
# Vercel 대시보드 → Project Settings → Git → Deploy Hooks 에서 생성
# ────────────────────────────────────────────────────────────
# NEXT_PUBLIC_ 접두사를 붙여야 브라우저(React)에서 접근 가능.
# SiteConfigPanel의 "게시" 버튼이 이 URL을 사용.
NEXT_PUBLIC_VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/your-hook-url
